{
  "name": "vehicle-diagnostic-core",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.28.1",
  "scripts": {
    "dev": "pnpm -r --parallel --if-present dev",
    "build": "pnpm -r --if-present build",
    "build:web": "pnpm --filter @core/shared build && pnpm --filter @core/web build",
    "build:api": "pnpm --filter @core/shared build && pnpm --filter @core/api build",
    "start": "pnpm --filter @core/api start",
    "start:api": "pnpm --filter @core/api start",
    "lint": "pnpm -r --if-present lint"
  },
  "devDependencies": {
    "@vercel/node": "^5.7.15",
    "typescript": "^5.8.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  }
}
